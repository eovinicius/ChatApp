{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (ChatApp.Api)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}\\app\\src\\ChatApp.Api\\bin\\Debug\\net10.0\\ChatApp.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}\\app\\src\\ChatApp.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal"
    },
    {
      "name": ".NET Core Attach (dotnet run já em execução)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
